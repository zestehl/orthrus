#!/bin/bash
# Check-agathos - Verify Agathos package structure
# Usage: check-agathos [--full]

set -e

HERMES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$HERMES_ROOT"

echo ""
echo "=== Agathos Module Structure ==="
echo "Module: agathos/__init__.py"
echo "Public exports:"
grep -E '^\s+"' agathos/__init__.py | sed 's/^/  /'

echo ""
echo "=== File Structure ==="
ls -la agathos/*.py agathos/*.sql 2>/dev/null | awk '{print $9, $5 " bytes"}'

echo ""
echo "=== Syntax Check ==="
python3 -m py_compile agathos/__init__.py agathos/entropy.py agathos/actions.py agathos/notifications.py 2>&1 && echo "✓ Core modules have valid syntax"

if [[ "$1" == "--full" ]]; then
    echo ""
    echo "=== Quick Smoke Test ==="
    cd tests/agathos/simulation
    python3 run_all_tests.py --quick
fi

echo ""
echo "=== Check Complete ==="
echo "Note: Full import test requires Python 3.10+ environment (hermes-agent dependency)"
